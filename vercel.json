{
  "buildCommand": "npx prisma generate && npx vite build && npx esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://res.cloudinary.com https://*.cloudinary.com https://flagcdn.com; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://api.stripe.com https://api-m.paypal.com https://api-m.sandbox.paypal.com https://api.cloudinary.com https://api.remove.bg https://api.resend.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(self)"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "mybabyshire.com"
        }
      ],
      "destination": "https://www.mybabyshire.com",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "mybabyshire.com"
        }
      ],
      "destination": "https://www.mybabyshire.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/admin-google-start", "destination": "/api/admin/login?authMode=admin-google" },
    { "source": "/api/admin-google-callback", "destination": "/api/admin/login?authMode=admin-google" },
    { "source": "/api/account/google/start", "destination": "/api/admin/login" },
    { "source": "/api/account/google/callback", "destination": "/api/admin/login" },
    { "source": "/api/account/me", "destination": "/api/admin/login?accountRoute=me" },
    { "source": "/api/account/profile", "destination": "/api/admin/login?accountRoute=profile" },
    { "source": "/api/account/addresses", "destination": "/api/admin/login?accountRoute=addresses" },
    { "source": "/api/account/orders", "destination": "/api/admin/login?accountRoute=orders" },
    { "source": "/login", "destination": "/" },
    { "source": "/login/account", "destination": "/" },
    { "source": "/login/admin", "destination": "/" },
    { "source": "/admin", "destination": "/" },
    { "source": "/admin/(.*)", "destination": "/" },
    { "source": "/account", "destination": "/" },
    { "source": "/account/(.*)", "destination": "/" },
    { "source": "/products/(.*)", "destination": "/" },
    { "source": "/checkout", "destination": "/" },
    { "source": "/track-order", "destination": "/" },
    { "source": "/payment-success", "destination": "/" },
    { "source": "/payment-cancel", "destination": "/" },
    { "source": "/paypal-success", "destination": "/" }
  ]
}
